PORT=3001

# Sift app database (Neon Postgres) — use a dedicated database for this project.
# Pooled connection (PgBouncer) for the app runtime:
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/sift?sslmode=require&channel_binding=require&pgbouncer=true"
# Direct (non-pooled) connection for Prisma migrations:
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/sift?sslmode=require&channel_binding=require"

# Auth
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# LLM — OpenAI-compatible providers, tried in LLM_FALLBACK_ORDER (first success wins).
# A provider is only used if its API key is set. Each is OpenAI-compatible.
LLM_FALLBACK_ORDER=groq,gemini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# Max LLM generations per day across the whole instance (abuse/cost ceiling).
# Set to 0 to disable the cap. Default 500.
LLM_DAILY_LIMIT=500

# Local embedding model for RAG (runs in-process, no API/quota). Default shown.
# Switching models means re-introspecting so embeddings match the new dimension.
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5
